{
  "id": "work-unit",
  "version": "4.0.0",
  "artifactType": "work-unit",
  "documentClass": "execution-unit",
  "maximumSectionDepth": 2,
  "commonRequiredSections": [],
  "profileRequiredSections": [
    {"id": "basis", "title": "Basis", "requiredKinds": ["intake-basis-ref"], "contains": ["Intake and Specification references", "requirement and decision references", "relevant evidence", "Specification check requirement"]},
    {"id": "work-definition", "title": "Work Definition", "requiredKinds": ["goal", "scope", "out-of-scope", "expected-output"], "contains": ["single goal", "scope and exclusions", "constraints and assumptions", "dependencies and order", "expected output"]},
    {"id": "plan", "title": "Plan", "requiredKinds": ["plan-step"], "contains": ["Plan to Work to AI Review to Report", "TDD order when applicable", "runtime actions"]},
    {"id": "execution-context", "title": "Execution Context", "requiredKinds": ["execution-context"], "contains": ["Goal id and objective", "exec reference", "execution agent", "repository and base ref", "dedicated branch", "canonical repository-local linked worktree", "setup active and cleanup state", "optional versioned execution state and immutable attempt history"]},
    {"id": "acceptance-and-verification", "title": "Acceptance and Verification", "requiredKinds": ["acceptance-criterion", "definition-of-done", "test-criterion", "quality-check"], "contains": ["acceptance criteria", "Definition of Done", "verification criteria", "quality gate", "required evidence"]},
    {"id": "execution", "title": "Execution", "requiredKinds": ["execution-result"], "contains": ["phase progress", "commands and runtime actions", "changed artifacts", "test results", "deviations"]},
    {"id": "ai-review", "title": "AI Review", "requiredKinds": ["ai-checklist", "ai-review-result"], "contains": ["AI checklist", "scope and instruction compliance", "verification result", "remaining risks"]},
    {"id": "human-review", "title": "Human Review", "requiredKinds": ["human-checklist", "human-review-method", "human-review-result"], "contains": ["Human checklist", "inspection method", "approval and rework criteria", "merge and PR promotion boundaries"]},
    {"id": "report", "title": "Report", "requiredKinds": ["report-result"], "contains": ["execution summary", "normalized integration result and registered raw receipt when integration occurs", "artifact and evidence references", "verification result", "Specification result", "remaining risks and unresolved items"]}
  ],
  "optionalSections": [
    {"id": "rework-history", "title": "Rework History", "contains": ["rework requests and results"]},
    {"id": "release-or-deployment", "title": "Release or Deployment", "contains": ["release or deployment actions and evidence"]}
  ],
  "blockGuidance": "Use registered blocks for large logs, screenshots, and non-JSON execution evidence.",
  "storageContract": "sectioned-document-package-v2",
  "implementationStatus": "implemented"
}
