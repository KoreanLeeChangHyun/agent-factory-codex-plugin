{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-factory.local/schemas/specification/v1/metadata.schema.json",
  "title": "Agent Factory Specification Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "documentVersion", "id", "artifactType", "projectId",
    "documentClass", "documentProfile", "lifecycle", "createdAt", "updatedAt",
    "language", "theme", "provenance", "relations"
  ],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "documentVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "artifactType": {"const": "specification"},
    "projectId": {"type": "string", "minLength": 1},
    "documentClass": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "documentProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "status"],
      "properties": {
        "phase": {"const": "specification"},
        "status": {"const": "draft"}
      }
    },
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"},
    "language": {"type": "string", "minLength": 2},
    "theme": {"type": "string", "minLength": 1},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["createdBy", "generatedBy", "sourceRefs"],
      "properties": {
        "createdBy": {"type": "string", "minLength": 1},
        "generatedBy": {"type": "string", "minLength": 1},
        "sourceRefs": {"$ref": "#/$defs/typedRefs"}
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "target": {"$ref": "#/$defs/typedRef"}
        }
      }
    }
  },
  "$defs": {
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sectionId", "itemId"],
      "properties": {
        "sectionId": {"type": "string", "pattern": "^[A-Za-z0-9]+(?:[-_.][A-Za-z0-9]+)*$"},
        "itemId": {"type": "string", "pattern": "^[A-Za-z0-9]+(?:[-_.][A-Za-z0-9]+)*$"}
      }
    },
    "typedRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactType", "id", "path"],
      "properties": {
        "artifactType": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
        "id": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "anchor": {"$ref": "#/$defs/anchor"}
      }
    },
    "typedRefs": {"type": "array", "items": {"$ref": "#/$defs/typedRef"}}
  },
  "x-statusTransitions": {"draft": []}
}
