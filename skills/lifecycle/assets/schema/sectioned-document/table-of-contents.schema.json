{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-factory.local/schemas/common/sectioned-document/table-of-contents.schema.json",
  "title": "Agent Factory Document Table Of Contents",
  "type": "object",
  "additionalProperties": false,
  "required": ["managerOwned", "sections", "sha256"],
  "properties": {
    "managerOwned": {"const": true, "readOnly": true},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "subsections"],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "path": {"type": "string", "pattern": "^data/sections/[A-Za-z0-9._-]+\\.json$"},
          "subsections": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id"],
              "properties": {"id": {"$ref": "#/$defs/id"}}
            }
          }
        }
      }
    },
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$", "readOnly": true}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[A-Za-z0-9]+(?:[-_.][A-Za-z0-9]+)*$"}}
}
