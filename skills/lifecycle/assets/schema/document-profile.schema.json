{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-factory.local/schemas/common/document-profile.schema.json",
  "title": "Agent Factory Document Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "version", "artifactType", "documentClass", "maximumSectionDepth",
    "commonRequiredSections", "profileRequiredSections", "optionalSections",
    "storageContract", "implementationStatus"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "artifactType": {"enum": ["intake", "specification", "work-unit"]},
    "documentClass": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "maximumSectionDepth": {"const": 2},
    "commonRequiredSections": {"$ref": "#/$defs/sections"},
    "profileRequiredSections": {"$ref": "#/$defs/sections"},
    "optionalSections": {"$ref": "#/$defs/sections"},
    "blockGuidance": {"type": "string", "minLength": 1},
    "storageContract": {"const": "sectioned-document-package-v2"},
    "implementationStatus": {"enum": ["implemented", "registered", "migration-required"]}
  },
  "$defs": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "contains"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "title": {"type": "string", "minLength": 1},
        "requiredKinds": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "uniqueItems": true
        },
        "contains": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {"$ref": "#/$defs/section"}
    }
  }
}
