{
  "id": "decisions-and-open-items",
  "title": "Decisions and Open Items",
  "content": [
    {
      "id": "NORM-0001",
      "kind": "decision-status",
      "content": {
        "status": "supported",
        "architecture": "one-agent-factory-plugin-plus-one-vscode-workspace-extension",
        "agentFactoryPluginOwns": [
          "14 bundled Agent Factory skills",
          "lifecycle and execution instructions",
          "deterministic scripts including worktree management",
          "optional hooks",
          "optional MCP server and connector configuration",
          "plugin manifest, version and distribution metadata"
        ],
        "vscodeWorkspaceExtensionOwns": [
          "Dashboard, Kanban, Viewer and Context UI",
          "canonical JSON and connected block loading and rendering",
          "workspace file observation and allowed artifact edits",
          "Kanban DnD and Work Unit selection",
          "Execution submission and streamed status presentation",
          "local codex app-server client lifecycle"
        ],
        "integrationBoundary": {
          "protocol": "Codex app-server JSON-RPC",
          "preferredTransport": "stdio JSONL",
          "reason": "stdio is the documented default local transport; WebSocket is currently experimental and unsupported.",
          "schema": "Generate TypeScript or JSON Schema from the installed Codex version and validate messages at the extension boundary."
        },
        "workUnitImpact": [
          "workspace-extension-four-tab-mvp remains the single VS Code extension implementation unit.",
          "agent-extension-goal-execution-integration should not create a second VS Code extension; it should be superseded or reshaped into Plugin packaging and Workspace Extension to app-server integration work.",
          "Agent Factory skill namespace and active installation decisions move to the Plugin manifest and marketplace installation contract."
        ]
      },
      "attributes": {
        "sourceKey": "recommendation",
        "normalization": "explicit-source",
        "sourceBlockRef": "blocks/legacy-source/01-agent-factory-plugin-vscode-extension-architecture.json"
      },
      "sourceRefs": [
        {
          "artifactType": "legacy-intake-source",
          "id": "agent-factory-plugin-vscode-extension-architecture-source-1",
          "path": ".agent-factory/intakes/agent-factory-plugin-vscode-extension-architecture/blocks/legacy-source/01-agent-factory-plugin-vscode-extension-architecture.json"
        }
      ]
    },
    {
      "id": "NORM-0002",
      "kind": "decision-status",
      "content": {
        "status": "supported",
        "summary": "Agent Factory는 14개 스킬과 실행 자산을 묶는 Plugin 하나, Human workspace visibility와 control을 제공하는 VS Code Workspace Extension 하나로 구성하는 것이 현재 요구와 공식 extension boundaries에 가장 단순하게 부합한다. 실행 연동은 별도 Agent extension이 아니라 Workspace Extension의 codex app-server stdio client로 둔다."
      },
      "attributes": {
        "sourceKey": "conclusion",
        "normalization": "explicit-source",
